{
  "build": {
    "arduino": {
      "ldscript": "esp32c6_out.ld",
      "memory_type": "int_rom_64k_tcm"
    },
    "core": "esp32",
    "extra_flags": "-DARDUINO_ESP32C6_DEV -DARDUINO_USB_MODE=1 -DARDUINO_USB_CDC_ON_BOOT=1",
    "f_cpu": "160000000L",
